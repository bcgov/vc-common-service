PORT=3000
NODE_ENV=development


# ============================================================================
# DB General Configuration
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=vc_common_service
DB_LOGGING=false

# ============================================================================
# Integration Test Database Profile
# ============================================================================
# Export these values (or copy them into a local .env.test file) before running
# `npm run test:integration` against:
#   docker compose --profile test up -d db-test migrate-test seed-test
# DB_HOST=localhost
# DB_PORT=5433
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_NAME=vc_common_service_test
# NODE_ENV=test

# ============================================================================
# DB SSL Configuration
# ============================================================================
DB_SSL=false
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true
# DB_SSL_CA=/etc/postgres/certs/ca.crt

# ===========================================================================
# Swagger Configuration
# ===========================================================================
SWAGGER_ENABLED=true
SWAGGER_JSON_ENABLED=true

# ===========================================================================
# Key Provider Configuration
# ===========================================================================
CONNECTOR_ENCRYPTION_KEYS_PATH='./config/encryption-keys.json'
